{
  "cme_id": "CME-101",
  "control_name": "ASLR (Address Space Layout Randomization)",
  "description": "Randomizes memory layout of processes, making memory corruption exploits significantly harder by requiring the attacker to guess or leak addresses.",
  "tactic": "Harden",
  "category": "Kernel Hardening",
  "control_layer": "OS/Kernel",
  "cvss_vector_impacts": [
    {
      "metric": "AC",
      "from": "L",
      "to": "H",
      "rationale": "Attacker must defeat randomization via info leak or brute force"
    }
  ],
  "cwe_relationships": [
    "CWE-119",
    "CWE-120",
    "CWE-122",
    "CWE-787",
    "CWE-125",
    "CWE-416",
    "CWE-415"
  ],
  "verification": {
    "method": "Check kernel randomize_va_space sysctl is set to 2 (full randomization)",
    "commands": [
      {
        "command": "cat /proc/sys/kernel/randomize_va_space",
        "expected": "2",
        "platform": "linux"
      },
      {
        "command": "sysctl kernel.randomize_va_space",
        "expected": "kernel.randomize_va_space = 2",
        "platform": "linux"
      },
      {
        "command": "(Get-ProcessMitigation -System).ASLR.ForceRelocateImages",
        "expected": "ON",
        "platform": "windows"
      },
      {
        "command": "(Get-ProcessMitigation -System).ASLR.BottomUp",
        "expected": "ON",
        "platform": "windows"
      }
    ]
  },
  "d3fend_mapping": {
    "technique_id": "D3-SAOR",
    "technique_name": "Segment Address Offset Randomization"
  },
  "references": [
    {
      "source": "Red Hat Security Hardening Guide",
      "section": "Protecting against memory-based attacks"
    },
    {
      "source": "CIS RHEL 9 Benchmark",
      "section": "1.5.2 Ensure address space layout randomization (ASLR) is enabled"
    }
  ],
  "confidence": "High",
