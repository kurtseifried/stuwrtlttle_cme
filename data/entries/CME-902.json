{
  "cme_id": "CME-902",
  "control_name": "Disable Unused Network Services",
  "description": "Disables and masks unnecessary listening services (rpcbind, avahi-daemon, cups, postfix on non-mail servers). Each removed service eliminates an attack surface.",
  "tactic": "Harden",
  "category": "Protocol Hardening",
  "control_layer": "Network",
  "cvss_vector_impacts": [
    {
      "metric": "AV",
      "from": "N",
      "to": "L",
      "rationale": "Fewer network-accessible services means fewer remote attack vectors"
    }
  ],
  "cwe_relationships": [
    "CWE-284",
    "CWE-668"
  ],
  "verification": {
    "method": "List listening services and verify only necessary ones are active",
    "commands": [
      {
        "command": "ss -tlnp | grep -v '127.0.0.1\\|::1'",
        "expected": "Only expected services",
        "platform": "linux"
      },
      {
        "command": "Get-NetTCPConnection -State Listen | Where-Object { $_.LocalAddress -ne '127.0.0.1' -and $_.LocalAddress -ne '::1' } | Measure-Object | Select-Object -ExpandProperty Count",
        "expected": "Only expected services",
        "platform": "windows"
      }
    ]
  },
