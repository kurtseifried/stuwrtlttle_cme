{
  "cme_id": "CME-102",
  "control_name": "NX/XD Bit (Non-Executable Memory)",
  "description": "Hardware-enforced memory page permissions that prevent execution of code in data regions (stack, heap), blocking classic code injection.",
  "tactic": "Harden",
  "category": "Kernel Hardening",
  "control_layer": "OS/Kernel",
  "cvss_vector_impacts": [
    {
      "metric": "AC",
      "from": "L",
      "to": "H",
      "rationale": "Attacker must use ROP/JOP instead of direct shellcode injection"
    }
  ],
  "cwe_relationships": [
    "CWE-94",
    "CWE-119",
    "CWE-416"
  ],
  "verification": {
    "method": "Check CPU supports NX bit and kernel has it enabled",
    "commands": [
      {
        "command": "grep -q nx /proc/cpuinfo && echo 'NX enabled'",
        "expected": "NX enabled",
        "platform": "linux"
      },
      {
        "command": "dmesg | grep -i 'NX.*protection'",
        "expected": "NX (Execute Disable) protection: active",
        "platform": "linux"
      },
      {
        "command": "(Get-CimInstance Win32_OperatingSystem).DataExecutionPrevention_SupportPolicy",
        "expected": "3",
        "platform": "windows"
      }
    ]
  },
