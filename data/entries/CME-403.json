{
  "cme_id": "CME-403",
  "control_name": "TLS 1.3 Enforcement",
  "description": "Restricts all TLS connections to TLS 1.3 minimum, eliminating protocol downgrade attacks and leveraging TLS 1.3's reduced handshake, mandatory forward secrecy, and encrypted extensions.",
  "tactic": "Harden",
  "category": "Cryptographic Controls",
  "control_layer": "Network",
  "cvss_vector_impacts": [
    {
      "metric": "AC",
      "from": "L",
      "to": "H",
      "rationale": "TLS downgrade attacks impossible; forward secrecy mandatory"
    }
  ],
  "cwe_relationships": [
    "CWE-757",
    "CWE-327"
  ],
  "verification": {
    "method": "Verify minimum TLS version is 1.3",
    "commands": [
      {
        "command": "openssl s_client -connect localhost:443 -tls1_2 </dev/null 2>&1 | grep 'handshake failure'",
        "expected": "handshake failure",
        "platform": "any"
      },
      {
        "command": "[Net.ServicePointManager]::SecurityProtocol -band [Net.SecurityProtocolType]::Tls13",
        "expected": "Tls13",
        "platform": "windows"
      }
    ]
  },
  "confidence": "High",
  "platforms": [
    "Any"
  ],
  "cve_schema_version": "5.2.0",
  "cve_affected": [
    {
      "vendor": "microsoft",
      "product": "windows",
      "cpes": [
        "cpe:2.3:o:microsoft:windows_10:*:*:*:*:*:*:*:*",
        "cpe:2.3:o:microsoft:windows_11:*:*:*:*:*:*:*:*",
        "cpe:2.3:o:microsoft:windows_server_2019:*:*:*:*:*:*:*",
        "cpe:2.3:o:microsoft:windows_server_2022:*:*:*:*:*:*:*"
      ],
      "defaultStatus": "applicable"
    }
  ]
}
